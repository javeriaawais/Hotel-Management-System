<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="HotelController">

    <!-- Header -->
    <top>
        <VBox spacing="8">
            <Label text="Hotel Management System — Professional UI Demo"
                   style="-fx-text-fill: white; -fx-padding: 12; -fx-background-color: #1976D2;">
                <font>
                    <Font size="20"/>
                </font>
            </Label>
        </VBox>
    </top>

    <!-- Left sidebar: booking, services, housekeeping, recent activity log -->
    <left>
        <ScrollPane fitToWidth="true">
            <VBox spacing="12" style="-fx-padding: 12;">
                <!-- New reservation & booking -->
                <Label text="New Reservation &amp; Booking" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfGuest" promptText="Full Name"/>
                <ComboBox fx:id="cbRoomType" promptText="Room Type"/>
                <TextField fx:id="tfNights" promptText="Nights"/>
                <TextField fx:id="tfDiscount" promptText="Discount (%)" text="0"/>
                <Label text="Add Services"/>
                <VBox spacing="6">
                    <CheckBox fx:id="cbSpa" text="Spa Treatment"/>
                    <CheckBox fx:id="cbRoomService" text="Room Service"/>
                    <CheckBox fx:id="cbMiniBar" text="Mini-Bar"/>
                    <CheckBox fx:id="cbLaundry" text="Laundry"/>
                    <CheckBox fx:id="cbBreakfast" text="Breakfast"/>
                    <CheckBox fx:id="cbAirportPickup" text="Airport Pickup"/>
                </VBox>
                <Button text="Book Room &amp; Check In" onAction="#onCheckIn"/>

                <!-- Add services after check-in -->
                <Separator/>
                <Label text="Add Services (After Check-In)" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbOccupiedRoom" promptText="Select Occupied Room"/>
                <VBox spacing="6">
                    <CheckBox fx:id="cbSpa2" text="Spa Treatment"/>
                    <CheckBox fx:id="cbRoomService2" text="Room Service"/>
                    <CheckBox fx:id="cbMiniBar2" text="Mini-Bar"/>
                    <CheckBox fx:id="cbLaundry2" text="Laundry"/>
                    <CheckBox fx:id="cbBreakfast2" text="Breakfast"/>
                    <CheckBox fx:id="cbAirportPickup2" text="Airport Pickup"/>
                </VBox>
                <Button text="Add Selected Services" onAction="#onAddService"/>

                <!-- Housekeeping -->
                <Separator/>
                <Label text="Housekeeping &amp; Room Cleaning Status" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbNeedsCleaningRoom" promptText="Select Room Requiring Cleaning"/>
                <Button text="Mark as Cleaned" onAction="#onMarkCleaned"/>

                <!-- Recent activity log (kept as bottom-left) -->
                <Separator/>
                <Label text="Recent Activity" style="-fx-font-weight: bold;"/>
                <TextField fx:id="searchField" promptText="Search guest / room / action"/>
                <Button text="Refresh" onAction="#onRefresh"/>
                <TextArea fx:id="logArea" promptText="Activity log" prefRowCount="8"/>
            </VBox>
        </ScrollPane>
    </left>

    <!-- Center: checkout & billing + room overview table -->
    <center>
        <VBox spacing="12" style="-fx-padding: 12;">
            <!-- Checkout & billing (replaces top-right recent activity) -->
            <Label text="CheckOut &amp; Billing" style="-fx-font-weight: bold;"/>
            <HBox spacing="10">
                <ComboBox fx:id="cbCheckoutRoom" promptText="Select Room To Check-Out" />
                <TextField fx:id="tfCheckoutDiscount" promptText="Discount (%)" text="0" />
                <Button text="Final Check-Out" onAction="#onCheckout"/>
            </HBox>
            <TextArea fx:id="billArea" promptText="Bill Preview" prefRowCount="10"/>

            <!-- Hotel room status overview -->
            <Label text="Hotel Room Status Overview" style="-fx-font-weight: bold;"/>
            <TableView fx:id="roomTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colRoomNumber" text="Room" prefWidth="100"/>
                    <TableColumn fx:id="colRoomType" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="colRoomStatus" text="Status" prefWidth="140"/>
                    <TableColumn fx:id="colGuestNights" text="Guest / Nights" prefWidth="240"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <FlowPane fx:id="roomStatusPane" hgap="10" vgap="10" style="-fx-padding: 10;" />
        </ScrollPane>
    </bottom>

</BorderPane>
